Usage: assignIoPins [-help] [-align] [-debugPinAll] [-debugPinFile <fileName>] [-improveSI] [ {-pin {pinList} | -pin_file <fileName> | -exclude_pin_file <fileName>} [-moveFixedPin ] [ -ignore_group_pins ]] [ -autoBusGroup ]

-help                             # Prints out the command usage
-align                            # If you specify this option, each top I/O pin will be aligned with one of the instance pins with which it is connected.
                                  # (bool, optional)
-autoBusGroup                     # Specifies for automatic grouping of bus. (bool, optional)
-debugPinAll                      # Specify debugging for all pins (bool, optional)
-debugPinFile <fileName>          # Specify pin-list for partition or net in a file for debugging (string, optional)
-exclude_pin_file <fileName>      # Specify pin-list to be excluded for partition in a file (string, optional)
-ignore_group_pins                # Partial non #optimizeOrder#opt_order# pinGroup or netGroup pins ignored during selected pin assignment. (bool, optional)
-improveSI                        # Place pins as checkerboard on Mx+2 and Mx-2 layers to reduce signal-integrity problems down the flow. (bool, optional)
-moveFixedPin                     # If you use this parameter, the specified pins with a Fixed status can also be moved. (bool, optional)
-pin {pinList}                    # Specifies that only the specified pins should be assigned. (string, optional)
-pin_file <fileName>              # Specify pin-list for partition in a file (string, optional)


